rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // Phase 3: Primitive Definition & Global Helpers
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // Pillar 2: Validation Blueprints (The "Anti-Update-Gap")
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidLocation(data) {
      return data.keys().hasAll(['id', 'name', 'userId']) &&
             isValidId(data.id) &&
             data.name is string && data.name.size() <= 100 &&
             data.userId is string && data.userId == request.auth.uid;
    }

    function isValidDevice(data) {
      return data.keys().hasAll(['id', 'name', 'userId']) &&
             isValidId(data.id) &&
             data.name is string && data.name.size() <= 100 &&
             data.userId is string && data.userId == request.auth.uid;
    }

    function isValidReading(data) {
      return data.keys().hasAll(['timestamp', 'temperature', 'humidity']) &&
             data.timestamp is number &&
             data.temperature is number &&
             data.humidity is number;
    }

    // -------------------------------------------------------------------------
    // Match Blocks (The "Fortress" Rules)
    // -------------------------------------------------------------------------

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if true;

      match /push_subscriptions/{subId} {
        allow read, write: if true;
      }

      match /devices/{deviceId} {
        allow read, write: if true;

        match /history/{dateStr} {
          allow read, write: if true;

          match /readings/{readingId} {
            allow read, write: if true;
          }
        }

        match /dailyHistory/{dateStr} {
          allow read, write: if true;
        }
      }
    }

    match /deviceRegistry/{deviceId} {
      allow read, write: if true;
    }

    match /locations/{locationId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && isValidLocation(incoming());
      allow delete: if isSignedIn() && resource != null && resource.data.userId == request.auth.uid;
    }

    match /devices/{deviceId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && isValidDevice(incoming());
      allow delete: if isSignedIn() && resource != null && resource.data.userId == request.auth.uid;
    }

    match /sensors/{deviceId} {
      allow read, write: if isSignedIn();
    }

    match /sensor_readings/{readingId} {
      allow read, create: if isSignedIn();
    }

    match /sensorReadings/{readingId} {
      allow read, create: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || incoming().userId == request.auth.uid);
    }

    match /airMonitoring/{deviceId} {
      allow read, write: if true;
      
      match /readings/{readingId} {
        allow read, write: if true;
      }

      match /status_history/{changeId} {
        allow read, write: if true;
      }
    }

    match /alerts/{alertId} {
      allow read, write: if true;
    }

    match /status_history/{changeId} {
      allow read, create: if isSignedIn();
    }

    match /system_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
