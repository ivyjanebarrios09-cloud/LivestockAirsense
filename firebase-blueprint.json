{
  "entities": {
    "SensorReading": {
      "title": "Sensor Reading",
      "description": "A single sensor reading event",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "temperature": { "type": "number" },
        "humidity": { "type": "number" },
        "ammonia": { "type": "number" },
        "methane": { "type": "number" },
        "co2": { "type": "number" },
        "pm25": { "type": "number" },
        "pm10": { "type": "number" },
        "aqi": { "type": "number" }
      },
      "required": ["timestamp", "temperature", "humidity", "ammonia", "methane", "co2", "pm25", "pm10", "aqi"]
    },
    "SensorData": {
      "title": "Sensor Data",
      "description": "Latest sensor data for a device",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string" },
        "deviceName": { "type": "string" },
        "temperature": { "type": "number" },
        "temperatureLevel": { "type": "string" },
        "humidity": { "type": "number" },
        "humidityLevel": { "type": "string" },
        "co2": { "type": "number" },
        "co2Level": { "type": "string" },
        "aqi": { "type": "number" },
        "aqiLevel": { "type": "string" },
        "nh3": { "type": "number" },
        "nh3Level": { "type": "string" },
        "ch4": { "type": "number" },
        "ch4Level": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["deviceId", "deviceName", "temperature", "humidity", "co2", "aqi", "nh3", "ch4", "timestamp"]
    },
    "StatusChange": {
      "title": "Status Change",
      "description": "Sensor status change event",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "sensorName": { "type": "string" },
        "status": { "type": "string" },
        "reading": { "type": "number" }
      },
      "required": ["timestamp", "sensorName", "status", "reading"]
    },
    "Alert": {
      "title": "Alert",
      "description": "System alert for high sensor values",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "alertType": { "type": "string" },
        "severity": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["timestamp", "alertType", "severity", "message", "isRead"]
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Thresholds and global settings",
      "type": "object",
      "properties": {
        "refreshInterval": { "type": "number" },
        "tempThreshold": { "type": "number" },
        "co2Threshold": { "type": "number" },
        "aqiThreshold": { "type": "number" }
      },
      "required": ["refreshInterval", "tempThreshold", "co2Threshold", "aqiThreshold"]
    },
    "User": {
      "title": "User Profile",
      "description": "Authenticated user settings and profiles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "number" },
        "updatedAt": { "type": "number" },
        "selectedLocationId": { "type": "string" },
        "selectedDeviceId": { "type": "string" },
        "thresholds": { "type": "object" }
      },
      "required": ["uid", "email"]
    },
    "LocationDetail": {
      "title": "Location Detail",
      "description": "Farming facilities/barns tracked by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "animalCount": { "type": "number" },
        "baseTemp": { "type": "number" },
        "baseHumidity": { "type": "number" },
        "baseCo2": { "type": "number" },
        "baseAmmonia": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "userId"]
    },
    "Device": {
      "title": "Telemetry Device",
      "description": "Environmental monitoring device details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "locationId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "userId"]
    }
  },
  "firestore": {
    "/sensor_readings/{readingId}": {
      "schema": { "$ref": "#/entities/SensorReading" },
      "description": "Historical and real-time readings"
    },
    "/sensors/{deviceId}": {
      "schema": { "$ref": "#/entities/SensorData" },
      "description": "Latest sensor data documents"
    },
    "/status_history/{changeId}": {
      "schema": { "$ref": "#/entities/StatusChange" },
      "description": "Sensor status change logs"
    },
    "/alerts/{alertId}": {
      "schema": { "$ref": "#/entities/Alert" },
      "description": "System alerts"
    },
    "/system_settings/{settingId}": {
      "schema": { "$ref": "#/entities/SystemSettings" },
      "description": "System settings document"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and layout preferences"
    },
    "/locations/{locationId}": {
      "schema": { "$ref": "#/entities/LocationDetail" },
      "description": "Cultivation locations and base settings"
    },
    "/devices/{deviceId}": {
      "schema": { "$ref": "#/entities/Device" },
      "description": "ESP32 nodes registered by users"
    }
  }
}
